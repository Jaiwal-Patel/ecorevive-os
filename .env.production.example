COMPOSE_PROJECT_NAME=ecorevive-prod
ECOREVIVE_DOMAIN=YOUR_DOMAIN.example

DJANGO_SECRET_KEY=GENERATE_A_LONG_RANDOM_SECRET
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=YOUR_DOMAIN.example
DJANGO_CSRF_TRUSTED_ORIGINS=https://YOUR_DOMAIN.example
DJANGO_CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN.example
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000

POSTGRES_DB=ecorevive
POSTGRES_USER=ecorevive
POSTGRES_PASSWORD=GENERATE_A_STRONG_DATABASE_PASSWORD
POSTGRES_PORT=5432
REDIS_PASSWORD=GENERATE_A_STRONG_REDIS_PASSWORD

FOUNDER_EMAIL=ujaiwal@outlook.com
FOUNDER_FULL_NAME=Jaiwal Patel
FOUNDER_RECOVERY_EMAIL=
FOUNDER_RECOVERY_FULL_NAME=EcoRevive Founder Recovery

ORGANIZATION_NAME=EcoRevive Dubai
PROJECT_NAME=EcoRevive OS
SERVICE_CITY=Dubai
SERVICE_COUNTRY=United Arab Emirates
PUBLIC_SITE_URL=https://sites.google.com/view/ecorevive-dubai/home
PUBLIC_TAGLINE=Today's Actions. Tomorrow's Impact.

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=EcoRevive Dubai <no-reply@YOUR_DOMAIN.example>
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

WHATSAPP_ENABLED=false
WHATSAPP_GRAPH_API_VERSION=vXX.X
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_STATUS_UPDATED=ecorevive_status_updated
WHATSAPP_TEMPLATE_LANGUAGE=en_US

GUNICORN_WORKERS=3
